# Copy to `.env` in this directory (ignored by git). Loaded automatically by `agentsea`
# when you run commands from somewhere under this repo, or when `AGENTSEA_ROOT` points here.
#
# Existing shell environment variables always win — this file only fills unset keys.

THEGRID_API_KEY=
DIGITALOCEAN_ACCESS_TOKEN=

# Optional: override The Grid OpenAI-compatible inference API (default https://api.thegrid.ai/v1).
# Used for dev/staging keys, model catalog fetch, key validation, and agent upstream API config.
# OpenClaw/Claude Messages URLs follow the same env (e.g. dev → messages-beta.api.dev.thegrid.ai).
# THEGRID_API_URL=https://api.dev.thegrid.ai/v1

# DIGITALOCEAN_API_TOKEN=
# DO_API_TOKEN=

# Optional: full provisioning logs on stderr (SSH/API polling, credential hints)
# AGENTSEA_VERBOSE=1

# Optional: from WSL2, open dashboards using the distro LAN IP in Windows (broken loopback mirroring only).
# Opens http://172.x… instead of http://127.0.0.1 — may require extra OpenClaw gateway.controlUi.allowedOrigins.
# AGENTSEA_WSL_OPEN_BROWSER_LAN_IP=1

# Optional: when using sh/*.sh one-liners that download `digitalocean.js`, pin the artifact:
# AGENTSEA_BUNDLE_SHA256=<sha256 hex>
# Legacy: AGENTSEA_BUNDLE_SHA256

# UI marketing site — public CDN base for install.sh and cloud/agent bootstrap scripts.
# NEXT_PUBLIC_* is inlined at BUILD time, so set it in the deploy env and rebuild.
# Per environment: dev=https://agentsea.dev.thegrid.ai,
# staging=https://agentsea.staging.thegrid.ai, prod=https://agentsea.thegrid.ai
# NEXT_PUBLIC_AGENTSEA_PUBLIC_ORIGIN=https://agentsea.dev.thegrid.ai

# CLI/SDK — origin the `agentsea` CLI fetches bootstrap scripts + manifest from
# (runtime override). Normally pinned by install.sh per environment; defaults to
# https://agentsea.dev.thegrid.ai. Point at another environment's CDN to test it.
# AGENTSEA_CDN=https://agentsea.dev.thegrid.ai

# Optional: absolute path to this repo when your shell cwd is not under it (CLI dotenv + UI manifest loader)
# AGENTSEA_ROOT=/path/to/agentsea
# Legacy: AGENTSEA_ROOT

# Optional: log dotenv path + DigitalOcean token preload hints (no secret values)
# AGENTSEA_DEBUG=1
# AGENTSEA_DEBUG_ENV=1
# Legacy: AGENTSEA_DEBUG_ENV=1
