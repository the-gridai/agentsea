# Copy to `.env` in this directory (ignored by git). Loaded automatically by `grid-spawn`
# when you run commands from somewhere under this repo, or when `GRID_SPAWN_ROOT` points here.
#
# Existing shell environment variables always win — this file only fills unset keys.

THEGRID_API_KEY=
DIGITALOCEAN_ACCESS_TOKEN=

# Optional: override The Grid OpenAI-compatible inference API (default https://api.thegrid.ai/v1).
# Used for dev/staging keys, model catalog fetch, key validation, and agent LiteLLM upstream config.
# OpenClaw/Claude Messages URLs follow the same env (e.g. dev → messages-beta.api.dev.thegrid.ai).
# THEGRID_API_URL=https://api.dev.thegrid.ai/v1

# DIGITALOCEAN_API_TOKEN=
# DO_API_TOKEN=

# Optional: full provisioning logs on stderr (SSH/API polling, credential hints)
# SPAWN_VERBOSE=1

# Optional: from WSL2, open dashboards using the distro LAN IP in Windows (broken loopback mirroring only).
# Opens http://172.x… instead of http://127.0.0.1 — may require extra OpenClaw gateway.controlUi.allowedOrigins.
# SPAWN_WSL_OPEN_BROWSER_LAN_IP=1

# Optional: when using sh/*.sh one-liners that download `digitalocean.js`, pin the artifact:
# GRID_SPAWN_BUNDLE_SHA256=<sha256 hex>

# UI marketing site — public CDN base for install.sh and cloud/agent bootstrap scripts
# NEXT_PUBLIC_GRID_SPAWN_PUBLIC_ORIGIN=https://spawn.thegrid.ai

# Optional: absolute path to this repo when your shell cwd is not under it (CLI dotenv + UI manifest loader)
# GRID_SPAWN_ROOT=/path/to/grid-spawn

# Optional: log dotenv path + DigitalOcean token preload hints (no secret values)
# SPAWN_DEBUG=1
# GRID_SPAWN_DEBUG_ENV=1
