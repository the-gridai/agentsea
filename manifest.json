        "OPENAI_API_KEY": "${THEGRID_API_KEY}",
        "OPENAI_BASE_URL": "https://api.thegrid.ai/v1",
        "THEGRID_API_KEY": "${THEGRID_API_KEY}"
      },
      "notes": "Disabled in agentsea — agent tool loops are not reliable without Grid /v1/responses.",
      "icon": "https://raw.githubusercontent.com/the-gridai/agentsea/main/assets/agents/codex.png",
      "featured_cloud": [],
