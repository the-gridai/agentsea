      "added": "2025-07",
      "github_stars": 68201,
      "stars_updated": "2026-03-29",
      "language": "Rust",
      "runtime": "binary",
      "category": "cli",
      "tagline": "OpenAI's lightweight coding agent for the terminal",
      "tags": [
        "coding",
        "terminal",
        "openai"
      ]
    },
