{
  "agents": {
    "claude": {
      "name": "Claude Code",
      "description": "Anthropic's AI coding agent — reads your codebase, writes code, runs commands, and ships features",
      "url": "https://claude.ai",
      "install": "curl -fsSL https://claude.ai/install.sh | bash",
      "launch": "claude",
      "env": {
        "THEGRID_API_KEY": "${THEGRID_API_KEY}",
        "ANTHROPIC_BASE_URL": "https://api.thegrid.ai/api/v1",
        "ANTHROPIC_AUTH_TOKEN": "${THEGRID_API_KEY}",
        "ANTHROPIC_API_KEY": "",
        "CLAUDE_CODE_SKIP_ONBOARDING": "1",
        "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
      },
      "config_files": {
        "~/.claude/settings.json": {
          "theme": "dark",
          "permissions": {
            "defaultMode": "bypassPermissions",
            "dangerouslySkipPermissions": true
          }
        },
        "~/.claude.json": {
          "hasCompletedOnboarding": true,
          "bypassPermissionsModeAccepted": true
        }
      },
      "icon": "https://raw.githubusercontent.com/Spectral-Finance/grid-spawn/main/assets/agents/claude.png",
      "featured_cloud": [
        "digitalocean",
        "sprite"
      ],
      "creator": "Anthropic",
      "repo": "anthropics/claude-code",
      "license": "Proprietary",
      "created": "2025-02",
      "added": "2025-06",
      "github_stars": 84019,
      "stars_updated": "2026-03-29",
      "language": "Shell",
      "runtime": "node",
      "category": "cli",
      "tagline": "Anthropic's AI coding agent — plan, build, and ship code across your entire codebase",
      "tags": [
        "coding",
        "terminal",
        "agentic"
      ]
    },
    "openclaw": {
      "name": "OpenClaw",
      "description": "Personal AI assistant with multi-channel gateway + TUI",
      "url": "https://github.com/openclaw/openclaw",
      "install": "npm install -g openclaw",
      "launch": "openclaw tui",
      "pre_launch": "nohup openclaw gateway > /tmp/openclaw-gateway.log 2>&1 &",
      "env": {
        "THEGRID_API_KEY": "${THEGRID_API_KEY}",
        "OPENAI_API_KEY": "${THEGRID_API_KEY}",
        "OPENAI_BASE_URL": "https://api.thegrid.ai/api/v1"
      },
      "interactive_prompts": {
        "model_id": {
          "prompt": "Enter model ID",
          "default": "\u006f\u0070\u0065\u006e\u0072\u006f\u0075\u0074\u0065\u0072/auto"
        }
      },
      "icon": "https://raw.githubusercontent.com/Spectral-Finance/grid-spawn/main/assets/agents/openclaw.png",
      "featured_cloud": [
        "digitalocean",
        "sprite"
      ],
      "creator": "OpenClaw",
      "repo": "openclaw/openclaw",
      "license": "MIT",
      "created": "2025-11",
      "added": "2025-11",
      "github_stars": 339820,
      "stars_updated": "2026-03-29",
      "language": "TypeScript",
      "runtime": "bun",
      "category": "tui",
      "tagline": "Your personal AI — any channel, any model, from the terminal",
      "tags": [
        "coding",
        "tui",
        "gateway"
      ]
    },
    "codex": {
      "name": "Codex CLI",
      "description": "OpenAI's open-source coding agent",
      "url": "https://github.com/openai/codex",
      "install": "npm install -g @openai/codex",
