    "kilocode": {
      "name": "Kilo Code",
      "description": "All-in-one agentic engineering platform with CLI",
      "url": "https://github.com/Kilo-Org/kilocode",
      "install": "npm install -g @kilocode/cli",
      "launch": "kilocode",
      "env": {
        "KILO_PROVIDER_TYPE": "\u006f\u0070\u0065\u006e\u0072\u006f\u0075\u0074\u0065\u0072",
        "KILO_OPEN_ROUTER_API_KEY": "${THEGRID_API_KEY}",
        "THEGRID_API_KEY": "${THEGRID_API_KEY}"
      },
      "notes": "Kilo multi-provider CLI: KILO_PROVIDER_TYPE must match the routing slot used by other agents in this repo (see packages/cli/src/shared/vendor-routing.ts). KILO_OPEN_ROUTER_API_KEY is upstream env naming for the platform key.",
      "icon": "https://raw.githubusercontent.com/Spectral-Finance/grid-spawn/main/assets/agents/kilocode.png",
      "featured_cloud": [
        "digitalocean",
        "sprite"
      ],
