{
  "agents": {
    "claude": {
      "name": "Claude Code",
      "description": "Anthropic's AI coding agent — reads your codebase, writes code, runs commands, and ships features",
      "url": "https://claude.ai",
      "install": "curl -fsSL https://claude.ai/install.sh | bash",
      "launch": "claude",
      "env": {
        "THEGRID_API_KEY": "${THEGRID_API_KEY}",
        "ANTHROPIC_BASE_URL": "https://messages-beta.api.thegrid.ai",
        "ANTHROPIC_API_KEY": "${THEGRID_API_KEY}",
        "ANTHROPIC_DEFAULT_SONNET_MODEL": "text-prime",
        "ANTHROPIC_DEFAULT_HAIKU_MODEL": "text-standard",
        "ANTHROPIC_DEFAULT_OPUS_MODEL": "text-max",
        "CLAUDE_CODE_SUBAGENT_MODEL": "text-standard",
        "CLAUDE_CODE_SKIP_ONBOARDING": "1",
        "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
      },
      "config_files": {
        "~/.claude/settings.json": {
          "theme": "dark",
          "permissions": {
            "defaultMode": "bypassPermissions",
            "dangerouslySkipPermissions": true
          }
        },
        "~/.claude.json": {
          "hasCompletedOnboarding": true,
          "bypassPermissionsModeAccepted": true
        }
      },
      "icon": "https://raw.githubusercontent.com/the-gridai/agentsea/main/assets/agents/claude.png",
      "featured_cloud": [
        "digitalocean",
        "sprite"
      ],
      "creator": "Anthropic",
      "repo": "anthropics/claude-code",
      "license": "Proprietary",
      "created": "2025-02",
      "added": "2025-06",
      "github_stars": 84019,
      "sort_priority": 20,
      "stars_updated": "2026-03-29",
      "language": "Shell",
      "runtime": "node",
      "category": "cli",
      "tagline": "Anthropic's AI coding agent — plan, build, and ship code across your entire codebase",
      "tags": [
        "coding",
        "terminal",
        "agentic"
      ],
      "next_steps": [
        {
          "text": "Start a session — AgentSea connects you automatically, or run claude in your project folder."
        },
        {
          "text": "Ask Claude to explore your codebase, fix bugs, or ship a feature in plain language."
        },
        {
          "text": "Type /help inside Claude Code to see commands like /clear and /compact.",
          "link": {
            "label": "Quickstart guide",
            "url": "https://code.claude.com/docs/en/quickstart"
          }
        },
        {
          "text": "Reconnect later with agentsea connect or pick your server from agentsea list."
        }
      ]
    },
    "openclaw": {
      "name": "OpenClaw",
      "description": "Personal AI assistant with multi-channel gateway + TUI",
      "url": "https://github.com/openclaw/openclaw",
      "install": "npm install -g openclaw",
      "launch": "openclaw tui",
      "pre_launch": "nohup openclaw gateway > /tmp/openclaw-gateway.log 2>&1 &",
      "env": {
        "THEGRID_API_KEY": "${THEGRID_API_KEY}",
        "OPENAI_API_KEY": "${THEGRID_API_KEY}",
        "OPENAI_BASE_URL": "https://api.thegrid.ai/v1"
      },
      "interactive_prompts": {
        "model_id": {
          "prompt": "Enter model ID",
          "default": "agent-prime"
        }
      },
      "icon": "https://raw.githubusercontent.com/the-gridai/agentsea/main/assets/agents/openclaw.png",
      "featured_cloud": [
        "digitalocean",
        "sprite"
      ],
      "creator": "OpenClaw",
      "repo": "openclaw/openclaw",
      "license": "MIT",
      "created": "2025-11",
      "added": "2025-11",
      "github_stars": 339820,
      "sort_priority": 1,
      "stars_updated": "2026-03-29",
      "language": "TypeScript",
      "runtime": "bun",
      "category": "tui",
      "tagline": "Your personal AI — any channel, any model, from the terminal",
      "tags": [
        "coding",
        "tui",
        "gateway"
      ],
      "next_steps": [
        {
          "text": "Open the Control UI — AgentSea starts the gateway and opens it in your browser (SSH tunnel on cloud servers)."
        },
        {
          "text": "Chat in the terminal TUI (openclaw tui) or use the web Control UI — both talk to the same agent."
        },
        {
          "text": "Connect messaging channels like Telegram, WhatsApp, or Discord through the gateway.",
          "link": {
            "label": "Channels overview",
            "url": "https://docs.openclaw.ai/channels/overview"
          }
        },
        {
          "text": "Your heartbeat model keeps the agent responsive between messages — already configured by AgentSea."
        },
        {
          "text": "Reconnect anytime with agentsea connect or agentsea list.",
          "link": {
            "label": "OpenClaw docs",
            "url": "https://docs.openclaw.ai/"
          }
        }
      ]
    },
    "codex": {
      "name": "Codex CLI",
      "description": "OpenAI's open-source coding agent",
      "url": "https://github.com/openai/codex",
      "install": "npm install -g @openai/codex",
      "launch": "codex",
      "disabled": true,
      "disabled_reason": "Codex requires OpenAI Responses API tool loops; The Grid has no native /v1/responses yet. Use OpenClaw, Hermes, or Kilo until Grid ships Responses API support.",
