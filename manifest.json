      "env": {
        "OPENAI_API_KEY": "${THEGRID_API_KEY}",
        "OPENAI_BASE_URL": "https://api.thegrid.ai/api/v1",
        "THEGRID_API_KEY": "${THEGRID_API_KEY}"
      },
      "notes": "Works with THEGRID_API_KEY and OPENAI_BASE_URL pointing at api.thegrid.ai/api/v1; default Codex model is selected from The Grid catalogue in interactive provisioning (MODEL_ID/--model/preferences.json override).",
      "icon": "https://raw.githubusercontent.com/Spectral-Finance/grid-spawn/main/assets/agents/codex.png",
      "featured_cloud": [
        "digitalocean",
        "sprite"
      ],
