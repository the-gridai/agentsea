      "env": {
        "THEGRID_API_KEY": "${THEGRID_API_KEY}",
        "OPENAI_BASE_URL": "https://api.thegrid.ai/api/v1",
        "OPENAI_API_KEY": "${THEGRID_API_KEY}"
      },
      "notes": "Uses THEGRID_API_KEY. Also OpenAI-compatible via OPENAI_BASE_URL + OPENAI_API_KEY. Installs Python 3.11 via uv. Ships a local web dashboard (port 9119) for configuration, session monitoring, skill browsing, and gateway management — auto-exposed via SSH tunnel when run through Grid Spawn.",
      "icon": "https://raw.githubusercontent.com/Spectral-Finance/grid-spawn/main/assets/agents/hermes.png",
      "featured_cloud": [
        "digitalocean",
