{
  "name": "agentsea",
  "version": "0.1.0",
  "private": true,
  "description": "Launch any AI coding agent on any cloud — one command, your cloud account, wired to The Grid API.",
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    }
  },
  "scripts": {
    "dev": "npm run dev --workspace=@agentsea/ui",
    "dev:clean": "npm run dev:clean --workspace=@agentsea/ui",
    "build": "npm run build --workspaces --if-present",
    "build:cli": "npm run build --workspace=@agentsea/cli",
    "build:providers": "bash ./scripts/build-providers.sh",
    "dev:cli": "npm run build:cli && npm run start --workspace=@agentsea/cli",
    "agentsea": "npm exec --workspace=@agentsea/cli -- agentsea",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --check \"packages/*/src/**/*.{ts,tsx,scss,json,md}\" \"packages/*/README.md\" \"README.md\" \"manifest.json\"",
    "format:fix": "prettier --write \"packages/*/src/**/*.{ts,tsx,scss,json,md}\" \"packages/*/README.md\" \"README.md\" \"manifest.json\"",
    "test": "npm run test --workspaces --if-present",
    "test:cli": "npm run test --workspace=@agentsea/cli",
    "test:cli:integration": "npm run test:integration --workspace=@agentsea/cli",
    "test:cli:e2e:do": "npm run test:e2e:do --workspace=@agentsea/cli",
    "e2e:do:sequential:manifest": "bash ./sh/e2e/e2e.sh --cloud digitalocean --sequential --agents-from-manifest digitalocean --first-agent openclaw"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.19.0",
    "npm": ">=10"
  }
}
