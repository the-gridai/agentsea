{
  "name": "@agentsea/cli",
  "version": "0.2.0",
  "private": true,
  "description": "agentsea CLI — cloud agent provisioning for The Grid (static manifest + your cloud accounts).",
  "type": "module",
  "bin": {
    "agentsea": "./agentsea.cjs"
  },
  "files": [
    "cli.js",
    "agentsea.cjs",
    "README.md"
  ],
  "scripts": {
    "build": "npx --yes bun@1.3.9 build src/index.ts --outfile cli.js --target bun --minify --packages bundle",
    "dev": "npx --yes bun@1.3.9 run src/index.ts",
    "start": "npx --yes bun@1.3.9 run src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "AGENTSEA_SKIP_API_VALIDATION=1 npx --yes bun@1.3.9 test",
    "test:integration": "npx --yes bun@1.3.9 test src/__tests__/e2e",
    "test:e2e:local:config": "bash ../../sh/e2e/local/e2e-local.sh --tier config",
    "test:e2e:local": "bash ../../sh/e2e/local/e2e-local.sh --tier integration",
    "test:e2e:do": "npx --yes bun@1.3.9 test src/__tests__/e2e/digitalocean-agent-flows.test.ts",
    "test:watch": "npx --yes bun@1.3.9 test --watch",
    "verify:key-prompt": "npx --yes bun@1.3.9 run scripts/verify-key-prompt.ts",
    "compile": "npx --yes bun@1.3.9 build src/index.ts --compile --outfile agentsea"
  },
  "dependencies": {
    "@clack/prompts": "1.0.0",
    "@daytonaio/sdk": "0.160.0",
    "@agentsea/sdk": "*",
    "dotenv": "^16.6.1",
    "picocolors": "1.1.1",
    "valibot": "1.2.0"
  },
  "devDependencies": {
    "@types/bun": "1.3.8",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.2.0"
  }
}
