# Public CDN for bootstrap one-liners and manifest-backed install commands.
# Set this in the deployment environment before building the UI.
#
# Development: https://agentsea.dev.thegrid.ai
# Staging:     https://agentsea.staging.thegrid.ai
# Production:  https://agentsea.thegrid.ai
NEXT_PUBLIC_AGENTSEA_PUBLIC_ORIGIN=https://agentsea.dev.thegrid.ai

# Analytics is enabled by default for recognized production/staging/dev origins.
# Disable it for local builds, previews, and test deployments.
NEXT_PUBLIC_ENABLE_ANALYTICS=false
