{
  "name": "@agentsea/ui",
  "version": "0.1.0",
  "private": true,
  "description": "AgentSea web app — Next.js 15 + React 19 + SCSS Modules. Styled to match grid-ui.",
  "scripts": {
    "clean": "rm -rf .next .next-dev",
    "dev": "next dev --port 3011",
    "dev:clean": "npm run clean && next dev --port 3011",
    "build": "npm run sync:cdn-public && next build",
    "start": "next start --port 3011",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "sync:cdn-public": "bash scripts/sync-cdn-public.sh"
  },
  "dependencies": {
    "@agentsea/sdk": "*",
    "@tanstack/react-query": "^5.84.1",
    "mixpanel-browser": "^2.80.0",
    "next": "15.5.18",
    "phoenix": "^1.8.0",
    "react": "^19.1.2",
    "react-dom": "^19.1.2"
  },
  "devDependencies": {
    "@types/node": "^24.2.0",
    "@types/phoenix": "^1.6.6",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "eslint": "^9.32.0",
    "eslint-config-next": "15.5.18",
    "sass": "^1.90.0",
    "typescript": "^5.6.3"
  }
}
